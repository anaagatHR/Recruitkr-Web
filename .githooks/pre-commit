#!/usr/bin/env sh
# RecruitKr pre-commit guard — stops secrets from ever being committed.
#
# Enabled automatically via the root package.json "prepare" script
# (git config core.hooksPath .githooks). To bypass for a genuine false
# positive: git commit --no-verify
set -eu

fail() {
  echo ""
  echo "  ✖ Commit blocked by pre-commit secret guard:"
  echo "$1" | sed 's/^/      /'
  echo ""
  echo "  Fix it, or if this is a false positive: git commit --no-verify"
  echo ""
  exit 1
}

# 1) Never commit a real .env file (*.example is allowed).
staged_env=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '(^|/)\.env($|\.)' | grep -vE '\.example$' || true)
if [ -n "$staged_env" ]; then
  fail "env file(s) staged — these hold secrets:
$staged_env
  Unstage with: git restore --staged <file>"
fi

# 2) Scan ADDED lines in the staged diff for high-signal secret patterns.
secret_hits=$(git diff --cached --diff-filter=ACM -U0 \
  | grep -E '^\+' \
  | grep -EnI 'sk-[A-Za-z0-9_-]{16,}|GOCSPX-[A-Za-z0-9_-]+|private_[A-Za-z0-9+/=]{12,}|xsmtpsib-[A-Za-z0-9]+|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----|AIza[0-9A-Za-z_-]{20,}' \
  || true)
if [ -n "$secret_hits" ]; then
  fail "possible secret in staged changes:
$secret_hits"
fi

exit 0
