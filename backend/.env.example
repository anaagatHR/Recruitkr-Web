NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/recuitkr
# In production use a comma-separated list of the EXACT frontend origins
# (scheme + host, no trailing slash). Must include your Vercel/custom domain so
# both REST CORS (app.js) and Socket.IO CORS (socket.js) accept the browser.
# e.g. CORS_ORIGIN=https://www.recruitkr.com,https://recruitkr.com,https://recruitkr.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8080
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
# Public HTTPS URL of THIS backend on AWS (used in emails/links). No trailing slash.
# e.g. BACKEND_PUBLIC_URL=https://api.recruitkr.com
BACKEND_PUBLIC_URL=

# --- Puppeteer / Chromium (PDF resume rendering) ---
# In the Docker image these are set for you. On a bare EC2/host, install Chromium
# and point PUPPETEER_EXECUTABLE_PATH at it, and set PUPPETEER_NO_SANDBOX=true.
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_NO_SANDBOX=true
JWT_ACCESS_SECRET=replace_with_a_64_plus_character_secret
JWT_REFRESH_SECRET=replace_with_a_64_plus_character_secret
JWT_SECRET=replace_with_a_64_plus_character_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
PASSWORD_RESET_EXPIRES_MIN=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
CONTACT_RATE_LIMIT_MAX=5
BCRYPT_OR_ARGON2_PEPPER=replace_with_random_pepper
BREVO_EMAIL=your_brevo_sender@example.com
BREVO_SMTP_KEY=replace_with_your_brevo_smtp_key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Apache Solr (optional). When SOLR_URL is unset, job search falls back to a
# cached MongoDB query and the app runs normally. Point SOLR_URL at the Solr
# base URL (no core); SOLR_JOBS_CORE is the core/collection name.
SOLR_URL=http://localhost:8983/solr
SOLR_JOBS_CORE=jobs
SOLR_TIMEOUT_MS=4000
