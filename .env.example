# Frontend (Next.js) environment.
# Copy to .env.local for local development. On Vercel, set these in the
# Project > Settings > Environment Variables dashboard instead.

# Base URL of the Express backend API, including the /api/v1 suffix.
# Local dev: the Next.js rewrite proxies same-origin /api/v1 to this URL,
# so login/signup work without cross-origin CORS.
#
# PRODUCTION (Vercel): set this to your AWS backend host, e.g.
#   NEXT_PUBLIC_API_URL=https://api.recruitkr.com/api/v1
# DO NOT point it at the frontend domain (https://www.recruitkr.com/...) — the
# next.config rewrite would then loop back to Vercel and every /api/v1 call 404s.
# This var is read at BUILD time by next.config.mjs, so redeploy after changing it.
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Public site URL (used for SEO canonical/OG tags).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ImageKit public key (safe to expose; used for client-side uploads).
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key

# Set to "false" to hide the Google login button in the UI.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# Dev server port. The dev/start scripts already pin -p 3000; this is here
# for tooling that reads PORT.
PORT=3000

